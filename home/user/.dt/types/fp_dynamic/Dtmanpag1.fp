CONTROL	Dtmanpageview
{
   TYPE	file
   CONTAINER_TYPE	SUBPANEL
   CONTAINER_NAME	Clock
   POSITION_HINTS	last
   ICON	Dthover
   FILE_NAME	/usr/dt/appconfig/appmanager/C/Desktop_Apps/Dtmanpageview
   HELP_STRING	The Man Page Viewer (Dtmanpageview) action displays a man page in a Quick Help viewer window.
}
