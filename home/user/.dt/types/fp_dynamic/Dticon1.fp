CONTROL	Dticon
{
   TYPE	file
   CONTAINER_TYPE	SUBPANEL
   CONTAINER_NAME	Clock
   POSITION_HINTS	last
   ICON	Dtpaint
   FILE_NAME	/usr/dt/appconfig/appmanager/C/Desktop_Apps/Dticon
   HELP_STRING	The Icon Editor (Dticon) action runs the desktop Icon Editor. Use the Icon Editor to create and edit bitmap and pixmap image files.
}
